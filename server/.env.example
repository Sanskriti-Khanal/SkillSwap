MONGO_URI=mongodb://localhost:27017/skillswap
PORT=3000

# Authentication Secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Encryption Key for MFA (Must be a 32-byte hex string)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Google reCAPTCHA v2 secret key (https://www.google.com/recaptcha/admin)
# Value below is Google's published always-passes test key — replace in production.
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# Google Sign-In OAuth 2.0 Client ID (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Khalti ePayment (KPG v2) — https://admin.khalti.com/
KHALTI_SECRET_KEY=your_khalti_secret_key_here
KHALTI_BASE_URL=https://dev.khalti.com

# Client URL (used for Khalti/Google redirects)
CLIENT_URL=http://localhost:5173

# Cloudinary (https://console.cloudinary.com/settings/api-keys) for tutor application
# documents (government IDs, certificates, resumes, etc). Uploads use type:'private' —
# never publicly reachable; documents are only ever read via short-lived signed
# download URLs generated for admins (see src/config/storage.js). Leave placeholders
# until real credentials are available — upload/signed-url routes return 503 until
# these are set; the server still boots and runs fine without them.
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
STORAGE_SIGNED_URL_EXPIRY_SECONDS=300
